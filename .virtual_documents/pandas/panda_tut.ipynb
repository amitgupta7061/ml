# melt data & pivot 

df = pd.DataFrame({
    "country" : ["usa", "usa", "india", "india"],
    "year"    : [2021, 2022, 2021, 2022],
    "sales"   : [100, 200, 90, 60],
    "profit"  : [20, 25, 18, 22]
})

melted_data = df.melt(
    id_vars = ["country", "year"],
    value_vars = ["sales", "profit"],
    var_name = "metrics",
    value_name = "value"
)

original = melted_data.pivot(
    index = ["country", "year"],
    columns = "metrics",
    values = "value"
)

original


